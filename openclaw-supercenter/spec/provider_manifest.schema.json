{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProviderManifest",
  "type": "object",
  "required": ["provider_id", "base_url", "capabilities", "constraints", "supports_streaming"],
  "properties": {
    "provider_id": {"type": "string"},
    "display_name": {"type": "string"},
    "base_url": {"type": "string"},
    "capabilities": {"type": "array", "items": {"type": "string"}},
    "constraints": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "requires_vscode": {"type": "boolean"},
        "requires_display": {"type": "boolean"},
        "requires_network": {"type": "boolean"},
        "offline_ok": {"type": "boolean"}
      }
    },
    "supports_streaming": {"type": "boolean"},
    "version": {"type": "string"}
  }
}
