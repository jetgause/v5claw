{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Project",
  "type": "object",
  "required": ["project_id", "name"],
  "properties": {
    "project_id": {"type": "string"},
    "name": {"type": "string"},
    "repos": {"type": "array", "items": {"type": "object"}},
    "workspace_prefs": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "vscode_hooks_enabled": {"type": "boolean"},
        "embedded_ide_enabled": {"type": "boolean"}
      }
    },
    "default_mode": {"type": ["string", "null"]},
    "provider_pins": {"type": "object", "additionalProperties": {"type": "string"}}
  }
}
